---
// src/pages/index.astro - VoltFund Main Dashboard Console
import Layout from "../layouts/Layout.astro";

// High-velocity micro-allocated categories for our non-profit platform
const microFunds = [
  {
    id: "f1",
    title: "Direct Mutual Aid",
    amount: "$4,250.00",
    icon: "users",
    desc: "Immediate emergency cash transfers",
  },
  {
    id: "f2",
    title: "Community Pantries",
    amount: "$1,890.00",
    icon: "apple",
    desc: "Restocking regional food networks",
  },
  {
    id: "f3",
    title: "Legal Defense Fees",
    amount: "$3,100.00",
    icon: "scale",
    desc: "Retainers for civil rights protection",
  },
  {
    id: "f4",
    title: "Medical Supply Grants",
    amount: "$5,400.00",
    icon: "pill",
    desc: "Direct distribution of medical gear",
  },
];

// Immutable real-time transaction audit records (Initial baseline state)
const auditLogs = [
  {
    id: "tx1",
    channel: "Direct Mutual Aid",
    amount: "-$350.00",
    time: "12 mins ago",
    note: "Emergency housing gap payout verified by DR",
  },
  {
    id: "tx2",
    channel: "Community Pantries",
    amount: "-$1,200.00",
    time: "2 hours ago",
    note: "Bulk grain acquisition - Nashville Hub",
  },
  {
    id: "tx3",
    channel: "Medical Supply Grants",
    amount: "-$850.00",
    time: "5 hours ago",
    note: "Insulin distribution cold packs secured",
  },
];
---

<Layout title="VoltFund | Non-Profit Micro-Management Console">
  <div class="dashboard-layout">
    <nav class="sidebar" aria-label="Main Navigation">
      <div class="logo">
        <span class="logo-dot" aria-hidden="true"></span>
        <h1>VoltFund</h1>
      </div>
      <ul class="nav-links">
        <li><a href="#" aria-current="page" class="active">Overview</a></li>
        <li><a href="/allocations">Allocations</a></li>
        <li><a href="/audit-logs">Audit Logs</a></li>
        <li><a href="/settings">Settings</a></li>
      </ul>
    </nav>

    <main id="main-content" class="workspace">
      <header class="workspace-header">
        <div>
          <h2>Micro-Management Console</h2>
          <p class="subtitle">
            Direct, high-velocity community funding channels
          </p>
        </div>
        <div class="user-profile" aria-label="User Profile">DR</div>
      </header>

      <div class="metrics-grid">
        <section
          class="card total-pool"
          aria-labelledby="pool-title"
          aria-live="polite"
          aria-atomic="true"
        >
          <h3 id="pool-title" class="card-label">Total Liquid Capital</h3>
          <div id="total-pool-balance" class="main-balance">$14,640.00</div>
          <p class="balance-subtext">Active operational reserves</p>
        </section>

        <section class="card quick-grant" aria-labelledby="grant-title">
          <h3 id="grant-title" class="card-label">
            Deploy Instant Micro-Grant
          </h3>
          <form id="quick-grant-form" class="grant-form">
            <div class="input-group">
              <label for="grant-amount" class="visually-hidden"
                >Grant Amount in USD</label
              >
              <input
                type="text"
                id="grant-amount"
                placeholder="0.00"
                aria-required="true"
              />
              <span class="currency-tag" aria-hidden="true">USD</span>
            </div>
            <button type="submit" class="primary-btn">Deploy Funds</button>
          </form>
        </section>
      </div>

      <section class="channels-section" aria-labelledby="channels-title">
        <h3 id="channels-title" class="section-label">
          Active Allocation Channels
        </h3>

        <div class="channels-grid">
          {
            microFunds.map((fund) => (
              <article
                class="channel-card"
                key={fund.id}
                aria-live="polite"
                aria-atomic="true"
              >
                <div class="channel-header">
                  <div class="channel-icon-wrapper">
                    <i data-lucide={fund.icon} class="channel-icon-graphic" />
                  </div>
                  <span class="channel-amount" data-card-amount={fund.title}>
                    {fund.amount}
                  </span>
                </div>
                <h4 class="channel-name">{fund.title}</h4>
                <p class="channel-desc">{fund.desc}</p>

                <button
                  class="secondary-btn btn-open-modal"
                  data-fund={fund.title}
                  aria-label={`Open allocation panel for ${fund.title}`}
                >
                  Manage Stream
                </button>
              </article>
            ))
          }
        </div>
      </section>

      <div class="activity-matrix">
        <section class="card chart-card" aria-labelledby="chart-title">
          <h3 id="chart-title" class="card-label">Weekly Velocity Stream</h3>
          <div
            id="weekly-chart-container"
            class="bar-chart-container"
            aria-label="Bar chart showing micro-grants distributed this week."
            aria-live="polite"
            aria-atomic="true"
          >
            <div
              class="chart-bar-wrapper"
              aria-label="Monday allocation total: 1,200 dollars"
            >
              <span class="bar-value" aria-hidden="true">$1.2k</span>
              <div class="chart-bar" style="height: 40%;"></div>
              <span class="bar-day" aria-hidden="true">Mon</span>
            </div>
            <div
              class="chart-bar-wrapper"
              aria-label="Tuesday allocation total: 800 dollars"
            >
              <span class="bar-value" aria-hidden="true">$800</span>
              <div class="chart-bar" style="height: 25%;"></div>
              <span class="bar-day" aria-hidden="true">Tue</span>
            </div>

            <div
              id="active-wednesday-wrapper"
              class="chart-bar-wrapper"
              aria-label="Wednesday allocation total: 3,400 dollars"
            >
              <span
                id="active-velocity-label"
                class="bar-value"
                aria-hidden="true">$3.4k</span
              >
              <div
                id="active-velocity-bar"
                class="chart-bar active-bar"
                style="height: 68%;"
              >
              </div>
              <span class="bar-day" aria-hidden="true">Wed</span>
            </div>

            <div
              class="chart-bar-wrapper"
              aria-label="Thursday allocation total: 1,500 dollars"
            >
              <span class="bar-value" aria-hidden="true">$1.5k</span>
              <div class="chart-bar" style="height: 50%;"></div>
              <span class="bar-day" aria-hidden="true">Thu</span>
            </div>
            <div
              class="chart-bar-wrapper"
              aria-label="Friday allocation total: 2,900 dollars"
            >
              <span class="bar-value" aria-hidden="true">$2.9k</span>
              <div class="chart-bar" style="height: 80%;"></div>
              <span class="bar-day" aria-hidden="true">Fri</span>
            </div>
          </div>
        </section>

        <section class="card logs-card" aria-labelledby="logs-title">
          <h3 id="logs-title" class="card-label">Live Audit Trail</h3>
          <ul
            id="log-feed-list"
            class="log-feed"
            role="list"
            aria-live="polite"
          >
            {
              auditLogs.map((log) => (
                <li class="log-item" key={log.id}>
                  <div class="log-item-left">
                    <div class="log-meta">
                      <span class="log-channel">{log.channel}</span>
                      <span class="log-time">{log.time}</span>
                    </div>
                    <p class="log-note">{log.note}</p>
                  </div>
                  <span
                    class="log-amount"
                    aria-label={`Amount subtracted: ${log.amount.replace("-", "")}`}
                  >
                    {log.amount}
                  </span>
                </li>
              ))
            }
          </ul>
        </section>
      </div>
    </main>
  </div>

  <dialog
    id="allocation-modal"
    class="action-modal"
    aria-labelledby="modal-headline"
  >
    <div class="modal-content">
      <header class="modal-header">
        <h3 id="modal-headline">Deploy Capital Stream</h3>
        <button
          id="close-modal-btn"
          class="close-icon-btn"
          aria-label="Close panel">✕</button
        >
      </header>
      <div class="modal-body">
        <p class="modal-context">
          Target Stream: <strong id="active-fund-name" class="highlight-text"
            >Selected Channel</strong
          >
        </p>
        <form id="modal-actual-form" class="modal-form">
          <div class="modal-input-wrapper">
            <label for="modal-amount">Allocation Amount</label>
            <div class="modal-input-group">
              <input
                type="text"
                id="modal-amount"
                placeholder="0.00"
                aria-required="true"
                autofocus
              />
              <span class="currency-label">USD</span>
            </div>
          </div>
          <div class="modal-input-wrapper">
            <label for="modal-notes">Verification / Audit Note</label>
            <textarea
              id="modal-notes"
              placeholder="Reason for direct distribution..."
              aria-required="true"></textarea>
          </div>
          <footer class="modal-actions">
            <button type="button" id="cancel-modal-btn" class="tertiary-btn"
              >Cancel</button
            >
            <button type="submit" class="primary-btn execution-btn"
              >Authorize Velocity Stream</button
            >
          </footer>
        </form>
      </div>
    </div>
  </dialog>

  <script>
    declare const lucide: any;
    if (typeof lucide !== "undefined") {
      lucide.createIcons();
    }

    const modal = document.getElementById(
      "allocation-modal",
    ) as HTMLDialogElement;
    const openButtons = document.querySelectorAll(".btn-open-modal");
    const closeBtn = document.getElementById("close-modal-btn");
    const cancelBtn = document.getElementById("cancel-modal-btn");
    const displayFundName = document.getElementById("active-fund-name");

    const modalForm = document.getElementById(
      "modal-actual-form",
    ) as HTMLFormElement;
    const modalAmountInput = document.getElementById(
      "modal-amount",
    ) as HTMLInputElement;
    const modalNotesInput = document.getElementById(
      "modal-notes",
    ) as HTMLInputElement;
    const totalPoolDisplay = document.getElementById("total-pool-balance");
    const logFeedList = document.getElementById("log-feed-list");

    const quickGrantForm = document.getElementById(
      "quick-grant-form",
    ) as HTMLFormElement;
    const quickAmountInput = document.getElementById(
      "grant-amount",
    ) as HTMLInputElement;

    let currentStreamName = "Selected Channel";

    // Initialized base total including our baseline visual state ($3,400)
    let wednesdayTotalVelocity = 3400;

    const validateAndSanitizeInput = (rawValue: string): number | null => {
      const cleanString = rawValue.trim().replace(/[$,]/g, "");

      if (cleanString === "") {
        alert("Transaction Failed: Please enter an allocation amount.");
        return null;
      }

      const parsedAmount = Number(cleanString);

      if (isNaN(parsedAmount)) {
        alert(
          "Transaction Failed: Letters or invalid characters detected. Please enter a pure numeric value.",
        );
        return null;
      }

      if (parsedAmount <= 0) {
        alert(
          "Transaction Failed: Deployment value must be a positive number greater than zero.",
        );
        return null;
      }

      return parsedAmount;
    };

    const executeDeductionEngine = (
      amount: number,
      channelName: string,
      notesText: string,
    ) => {
      if (totalPoolDisplay) {
        const currentBalance = parseFloat(
          totalPoolDisplay.textContent!.replace(/[$,]/g, ""),
        );
        const newBalance = currentBalance - amount;
        totalPoolDisplay.textContent = `$${newBalance.toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
      }

      const targetCardDisplay = document.querySelector(
        `[data-card-amount="${channelName}"]`,
      );
      if (targetCardDisplay) {
        const currentCardBalance = parseFloat(
          targetCardDisplay.textContent!.replace(/[$,]/g, ""),
        );
        const newCardBalance = currentCardBalance - amount;
        targetCardDisplay.textContent = `$${newCardBalance.toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
      }

      const activeBar = document.getElementById("active-velocity-bar");
      const activeLabel = document.getElementById("active-velocity-label");
      const wednesdayWrapper = document.getElementById(
        "active-wednesday-wrapper",
      );

      if (activeBar || activeLabel || wednesdayWrapper) {
        wednesdayTotalVelocity += amount;

        const maxVelocityCeiling = 10000;
        let heightPercentage =
          (wednesdayTotalVelocity / maxVelocityCeiling) * 100;

        let adaptiveHeight = Math.max(heightPercentage, 8);
        if (adaptiveHeight > 100) adaptiveHeight = 100;

        if (activeBar) {
          activeBar.style.height = `${adaptiveHeight}%`;
        }

        if (activeLabel) {
          if (wednesdayTotalVelocity < 100) {
            activeLabel.textContent = `$${wednesdayTotalVelocity.toFixed(0)}`;
          } else {
            const metricValue = (wednesdayTotalVelocity / 1000).toFixed(1);
            activeLabel.textContent = `$${metricValue}k`;
          }
        }

        // UPGRADED ACCESSIBILITY SPEECH LAYER GENERATOR
        if (wednesdayWrapper) {
          wednesdayWrapper.setAttribute(
            "aria-label",
            `Wednesday allocation total: ${wednesdayTotalVelocity.toLocaleString("en-US", { maximumFractionDigits: 0 })} dollars`,
          );
        }
      }

      if (logFeedList) {
        const formattedAmount = `-$${amount.toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
        const newLogItem = document.createElement("li");
        newLogItem.className = "log-item";

        newLogItem.innerHTML = `
          <div class="log-item-left">
            <div class="log-meta">
              <span class="log-channel">${channelName}</span>
              <span class="log-time">Just now</span>
            </div>
            <p class="log-note">${notesText}</p>
          </div>
          <span class="log-amount" aria-label="Amount subtracted: ${formattedAmount.replace("-", "")}">${formattedAmount}</span>
        `;
        logFeedList.insertBefore(newLogItem, logFeedList.firstChild);
      }
    };

    openButtons.forEach((button) => {
      button.addEventListener("click", (e) => {
        e.preventDefault();
        currentStreamName =
          button.getAttribute("data-fund") || "Selected Stream";
        if (displayFundName) displayFundName.textContent = currentStreamName;
        modal.showModal();
      });
    });

    const clearFormAndState = () => {
      if (modalForm) modalForm.reset();
    };

    closeBtn?.addEventListener("click", (e) => {
      e.preventDefault();
      modal.close();
    });
    cancelBtn?.addEventListener("click", (e) => {
      e.preventDefault();
      modal.close();
    });

    modal?.addEventListener("close", () => {
      clearFormAndState();
    });

    modalForm?.addEventListener("submit", function (event) {
      event.preventDefault();
      event.stopPropagation();

      const validatedAmount = validateAndSanitizeInput(modalAmountInput.value);
      if (validatedAmount === null) return false;

      const auditNotes =
        modalNotesInput.value.trim() || "Micro-grant distribution verified";

      executeDeductionEngine(validatedAmount, currentStreamName, auditNotes);
      modal.close();
    });

    quickGrantForm?.addEventListener("submit", function (event) {
      event.preventDefault();
      event.stopPropagation();

      const validatedInstantAmount = validateAndSanitizeInput(
        quickAmountInput.value,
      );
      if (validatedInstantAmount === null) return false;

      executeDeductionEngine(
        validatedInstantAmount,
        "Global Deployment",
        "Direct automated velocity route execution",
      );
      quickGrantForm.reset();
    });
  </script>
</Layout>

<style>
  /* System Layout Architecture Grid and Viewport Control */
  .dashboard-layout {
    display: flex;
    min-height: 100vh;
    background-color: var(--bg-main);
    overflow-x: hidden;
  }

  /* Sticky Left Sidebar Core Styles */
  .sidebar {
    width: 260px;
    background-color: var(--bg-main);
    border-right: 1px solid var(--border-color);
    padding: 40px 24px;
    display: flex;
    flex-direction: column;
    gap: 40px;
    position: sticky;
    top: 0;
    height: 100vh;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .logo-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent-gradient);
  }
  .logo h1 {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .nav-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* PREMIUM INTERACTION NAVIGATION HOVER ENGINES */
  .nav-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 15px;
    padding: 12px 16px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    transition:
      color 0.25s cubic-bezier(0.16, 1, 0.3, 1),
      background-color 0.25s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    border: 1px solid transparent;
  }
  .nav-links a:hover {
    color: var(--text-primary);
    background-color: var(--bg-surface);
    border-color: var(--border-color);
  }
  .nav-links a.active {
    color: var(--text-primary);
    background-color: var(--bg-surface-elevated);
    border-color: rgba(255, 78, 58, 0.15);
    font-weight: 600;
  }
  .nav-links a::after {
    content: "";
    width: 4px;
    height: 4px;
    background: var(--accent-gradient);
    border-radius: 50%;
    opacity: 0;
    transform: scale(0) translateX(4px);
    transition:
      opacity 0.2s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nav-links a:hover::after,
  .nav-links a.active::after {
    opacity: 1;
    transform: scale(1) translateX(0);
  }

  /* Main Workspace viewport layout config */
  .workspace {
    flex: 1;
    padding: 40px 48px;
    background-color: var(--bg-main);
    display: flex;
    flex-direction: column;
    gap: 40px;
    height: auto;
    min-height: 100vh;
    padding-bottom: 80px;
  }

  .workspace-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .workspace-header h2 {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }
  .subtitle {
    color: var(--text-muted);
    font-size: 14px;
    margin-top: 4px;
  }
  .user-profile {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--bg-surface-elevated);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 600;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 24px;
  }

  .card {
    background-color: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 32px;
  }

  .total-pool {
    position: relative;
    overflow: hidden;
  }
  .total-pool::before {
    content: "";
    position: absolute;
    top: -50px;
    right: -50px;
    width: 150px;
    height: 150px;
    background: var(--accent-glow);
    filter: blur(80px);
    opacity: 0.25;
    pointer-events: none;
  }

  .card-label {
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    margin-bottom: 16px;
    font-weight: 600;
  }

  .main-balance {
    font-size: 42px;
    font-weight: 700;
    letter-spacing: -1px;
  }
  .balance-subtext {
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 8px;
  }

  .grant-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .input-group {
    position: relative;
    display: flex;
    align-items: center;
  }
  .input-group input {
    width: 100%;
    background-color: var(--bg-main);
    border: 1px solid var(--bg-surface-elevated);
    border-radius: var(--radius-md);
    padding: 14px 16px;
    color: white;
    font-size: 18px;
    font-weight: 600;
  }
  .currency-tag {
    position: absolute;
    right: 16px;
    font-size: 12px;
    font-weight: 700;
    color: var(--text-muted);
  }

  .primary-btn {
    background: var(--accent-gradient);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    padding: 14px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }
  .primary-btn:hover {
    opacity: 0.9;
  }

  .section-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-muted);
    margin-bottom: 20px;
  }
  .channels-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 24px;
  }

  .channel-card {
    background-color: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease;
  }
  .channel-card:hover {
    background-color: var(--bg-surface-elevated);
  }

  .channel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .channel-icon-wrapper {
    background-color: var(--bg-main);
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.02);
  }
  .channel-icon-graphic {
    width: 18px;
    height: 18px;
    color: var(--text-muted);
    stroke-width: 2px;
  }

  .channel-amount {
    font-size: 18px;
    font-weight: 700;
  }
  .channel-name {
    font-size: 16px;
    font-weight: 600;
    margin-top: 4px;
  }
  .channel-desc {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.4;
    flex-grow: 1;
  }

  .secondary-btn {
    background-color: var(--bg-main);
    color: var(--text-primary);
    border: 1px solid var(--bg-surface-elevated);
    border-radius: var(--radius-md);
    padding: 10px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    margin-top: 8px;
    transition: all 0.2s ease;
  }
  .secondary-btn:hover {
    border-color: var(--accent-glow);
  }

  .activity-matrix {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 24px;
    margin-top: 12px;
  }

  .bar-chart-container {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    height: 180px;
    padding-top: 24px;
  }
  .chart-bar-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    height: 100%;
    justify-content: flex-end;
    width: 14%;
  }
  .bar-value {
    font-size: 10px;
    color: var(--text-muted);
    font-weight: 600;
  }
  .chart-bar {
    width: 100%;
    background-color: var(--bg-surface-elevated);
    border-radius: 4px;
    min-height: 8px;
    transition:
      background-color 0.3s ease,
      height 0.3s cubic-bezier(0.16, 1, 0.3, 1);
