---
// src/layouts/Layout.astro
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>VoltFund</title>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script is:inline>
      const savedTheme = localStorage.getItem("vtf_theme");
      const systemPrefersLight = window.matchMedia(
        "(prefers-color-scheme: light)",
      ).matches;

      if (savedTheme === "light" || (!savedTheme && systemPrefersLight)) {
        document.documentElement.classList.add("light-theme");
      } else {
        document.documentElement.classList.remove("light-theme");
      }
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <div class="app-container">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg-main: #0a0a0a;
    --bg-surface: #121212;
    --bg-surface-elevated: #1a1a1a;
    --text-primary: #ffffff;
    --text-muted: #a0a0a0;
    --border-color: rgba(255, 255, 255, 0.03);
    --input-bg: #0a0a0a;
    --input-text: #ffffff;
    --accent-gradient: linear-gradient(135deg, #ff4e3a 0%, #ff6b4a 100%);
    --accent-glow: #ff4e3a;
    --radius-md: 8px;
    --radius-lg: 16px;
  }

  html.light-theme {
    --bg-main: #f4f4f6;
    --bg-surface: #ffffff;
    --bg-surface-elevated: #ededf1;
    --text-primary: #121214;
    --text-muted: #6b6b76;
    --border-color: rgba(0, 0, 0, 0.05);
    --input-bg: #f4f4f6;
    --input-text: #121214;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    background-color: var(--bg-main);
    color: var(--text-primary);
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
    line-height: 1.5;
  }

  .skip-link {
    position: absolute;
    top: -100px;
    left: 20px;
    background: var(--accent-gradient);
    color: white;
    padding: 12px 24px;
    border-radius: var(--radius-md);
    font-weight: bold;
    z-index: 100;
  }
  .skip-link:focus {
    top: 20px;
  }

  button:focus-visible,
  a:focus-visible {
    outline: 3px solid var(--accent-glow);
    outline-offset: 4px;
  }
</style>
